# ============================================================================
# KuKuMBA — production environment. Copy to .env.production and fill in.
# Used both for docker compose interpolation AND injected into the api container.
# Run compose with:  --env-file .env.production
# ============================================================================

# ── Postgres (compose creates the DB with these) ──
POSTGRES_USER=kukumba
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=kukumba

# ── API runtime ──
# IMPORTANT: the password here MUST equal POSTGRES_PASSWORD above. Host is the
# compose service name "db". Do not expose this port publicly.
DATABASE_URL=postgresql://kukumba:CHANGE_ME_strong_db_password@db:5432/kukumba?schema=public
REDIS_URL=redis://redis:6379
API_PORT=3000
WEB_ORIGIN=https://kukumba.space

# Generate each with:  openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

DEFAULT_RTP=0.99
# "mock" = sandbox (no real money). Implement & switch a real provider later.
PAYMENT_PROVIDER=mock

# Admin account created by the seed
ADMIN_EMAIL=admin@kukumba.space
ADMIN_PASSWORD=CHANGE_ME_admin_password
ADMIN_USERNAME=kukumba_admin
DEMO_SIGNUP_BONUS=5000

# Seed the DB on first boot (currencies, game, VIP, admin, content, demo raffle).
# Set to true for the FIRST deploy, then change to false and redeploy.
SEED_ON_START=true

# Email for Let's Encrypt renewal notices (used by deploy/init-letsencrypt.sh)
CERTBOT_EMAIL=you@example.com
# Set to 1 to test against the LE staging CA (avoids rate limits while debugging)
CERTBOT_STAGING=0
