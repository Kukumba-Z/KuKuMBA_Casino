// ─────────────────────────────────────────────────────────────────────────────
// KuKuMBA — database schema (the single source of truth for the whole platform).
// Modular by design: each feature maps to one or more models below.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  PARTNER
  SUPPORT
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  SELF_EXCLUDED
}

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum CurrencyType {
  DEMO
  FIAT
  CRYPTO
}

enum WalletMode {
  DEMO
  REAL
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET
  WIN
  REFUND
  BONUS
  CASHBACK
  RAKEBACK
  REFERRAL
  PROMO
  RAFFLE_ENTRY
  RAFFLE_PRIZE
  TIP
  ADMIN_ADJUST
  ROLLBACK
  CONVERSION
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum TxStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum DepositStatus {
  PENDING
  CONFIRMING
  COMPLETED
  FAILED
  EXPIRED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
  FAILED
}

enum BetStatus {
  PENDING
  WON
  LOST
  PUSH
  VOID
}

enum BonusType {
  WELCOME
  DEPOSIT
  RELOAD
  FREEBET
  NO_DEPOSIT
  CASHBACK
}

enum BonusStatus {
  ACTIVE
  WAGERING
  COMPLETED
  LOST
  EXPIRED
  CANCELLED
  FORFEITED
}

enum PromoType {
  BALANCE
  BONUS
  FREEBET
}

enum RaffleStatus {
  DRAFT
  OPEN
  DRAWING
  COMPLETED
  CANCELLED
}

enum RaffleCreatorType {
  ADMIN
  PARTNER
  SYSTEM
}

enum RaffleAudience {
  ALL
  PARTNER_REFERRALS
}

enum TicketStatus {
  OPEN
  PENDING
  ANSWERED
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationType {
  SYSTEM
  DEPOSIT
  WITHDRAWAL
  WIN
  BONUS
  PROMO
  REFERRAL
  KYC
  RAFFLE
  VIP
  SUPPORT
  SECURITY
}

enum RgLimitType {
  DEPOSIT
  LOSS
  WAGER
  SESSION_TIME
}

// ── Core identity ──────────────────────────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  accountId       Int        @unique // public, human-friendly Account ID (e.g. 100001)
  email           String     @unique
  emailVerified   Boolean    @default(false)
  username        String     @unique
  passwordHash    String
  role            UserRole   @default(USER)
  status          UserStatus @default(ACTIVE)
  bonusAccess     Boolean    @default(true) // admin can revoke access to bonuses/promocodes
  avatarUrl       String?
  countryCode     String?
  locale          String     @default("ru")
  kycStatus       KycStatus  @default(NONE)
  twoFactorSecret String?
  twoFactorEnabled Boolean   @default(false)
  chatMutedUntil  DateTime? // set by moderators; blocks chat sending while in the future

  // referral
  referralCode String  @unique
  referredById String?
  referredBy   User?   @relation("UserReferrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("UserReferrals")

  // VIP progression is dual-track: lifetime REAL deposits AND lifetime REAL
  // wagers, both in USD-equivalent. A level unlocks only when BOTH thresholds
  // of the VipLevel row are met (see VipService.levelFor).
  vipLevel      Int     @default(0)
  vipDepositUsd Decimal @default(0) @db.Decimal(38, 18)
  vipWagerUsd   Decimal @default(0) @db.Decimal(38, 18)

  // Lifetime play stats — persisted counters so the profile numbers survive
  // GameRound/Bet pruning (they're incremented per round, never recomputed).
  lifetimeBets    Int     @default(0)
  lifetimeWagered Decimal @default(0) @db.Decimal(38, 18)

  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // relations
  balances        Balance[]
  transactions    Transaction[]
  sessions        Session[]
  linkedAccounts  LinkedAccount[]
  seeds           ProvablyFairSeed[]
  rounds          GameRound[]
  bets            Bet[]
  deposits        Deposit[]
  withdrawals     Withdrawal[]
  userBonuses     UserBonus[]
  promoRedemptions PromoRedemption[]
  referralEarningsReceived ReferralEarning[] @relation("ReferralEarner")
  referralEarningsGenerated ReferralEarning[] @relation("ReferralSource")
  referralCommissionsReceived ReferralCommission[] @relation("ReferralCommissionEarner")
  referralCommissionsGenerated ReferralCommission[] @relation("ReferralCommissionSource")
  referralBalances ReferralBalance[] @relation("ReferralBalanceOwner")
  cashbackClaims  CashbackClaim[]
  rakebackAccruals RakebackAccrual[]
  raffleEntries   RaffleEntry[]
  raffleWins      RaffleWinner[]
  chatMessages    ChatMessage[]
  notifications   Notification[]
  kycCase         KycCase?
  tickets         SupportTicket[]
  rgLimits        RgLimit[]
  selfExclusions  SelfExclusion[]

  @@index([referredById])
  @@index([role])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  userAgent        String?
  ip               String?
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
}

model LinkedAccount {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String // "google" | "telegram" | "steam" | ...
  providerUserId String
  displayName    String?
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
}

// ── Wallet & ledger ────────────────────────────────────────────────────────────

model Currency {
  code          String       @id // "DEMO" | "USD" | "BTC" | "USDT" | ...
  name          String
  type          CurrencyType
  symbol        String?
  decimals      Int          @default(2)
  networks      String[] // crypto networks, e.g. ["ERC20","TRC20","TON","SOL","BSC"]
  minDeposit    Decimal      @default(0) @db.Decimal(38, 18)
  minWithdrawal Decimal      @default(0) @db.Decimal(38, 18)
  usdRate       Decimal      @default(1) @db.Decimal(38, 18) // 1 unit = X USD (display/aggregation)
  enabled       Boolean      @default(true)
  isDefault     Boolean      @default(false)
  sortOrder     Int          @default(0)
}

model Balance {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency  String
  mode      WalletMode
  amount    Decimal    @default(0) @db.Decimal(38, 18)
  locked    Decimal    @default(0) @db.Decimal(38, 18)
  updatedAt DateTime   @updatedAt

  @@unique([userId, currency, mode])
  @@index([userId])
}

/// Immutable, append-only ledger. balanceAfter lets us audit & reconcile.
model Transaction {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          TransactionType
  direction     LedgerDirection
  currency      String
  mode          WalletMode
  amount        Decimal         @db.Decimal(38, 18) // positive magnitude
  balanceBefore Decimal         @db.Decimal(38, 18)
  balanceAfter  Decimal         @db.Decimal(38, 18)
  status        TxStatus        @default(COMPLETED)
  refType       String?
  refId         String?
  description   String?
  meta          Json?
  createdAt     DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([type])
  @@index([refType, refId])
}

model Deposit {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency  String
  network   String?
  mode      WalletMode    @default(REAL)
  amount    Decimal       @db.Decimal(38, 18)
  address   String?
  txHash    String?
  provider  String        @default("mock")
  status    DepositStatus @default(PENDING)
  bonusKey  String? // the deposit bonus the player explicitly chose (null = no bonus)
  meta      Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

model Withdrawal {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency     String
  network      String?
  amount       Decimal          @db.Decimal(38, 18)
  fee          Decimal          @default(0) @db.Decimal(38, 18)
  address      String
  provider     String           @default("mock")
  status       WithdrawalStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  txHash       String?
  meta         Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

// ── Games: provably-fair roulette ──────────────────────────────────────────────

/// A slot/game aggregator (or single provider) integration. Secrets are stored
/// encrypted (AES-256-GCM via PROVIDER_SECRETS_KEY) — never in plaintext — and
/// are masked in admin API responses.
model GameProvider {
  id               String   @id @default(cuid())
  key              String   @unique // slug used in callback URLs: /providers/:key/callback/*
  name             String
  kind             String   @default("MOCK") // adapter discriminator: MOCK | GENERIC_SEAMLESS | ...
  baseUrl          String? // provider's game-launch base URL
  apiKeyEnc        String? // encrypted outbound API key
  webhookSecretEnc String? // encrypted HMAC secret for inbound callbacks
  enabled          Boolean  @default(true)
  meta             Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  games        Game[]
  transactions ProviderTransaction[]
}

/// Idempotency + audit record for seamless-wallet callbacks. One row per
/// provider transaction id; a replayed callback finds the row and returns the
/// stored response instead of touching the wallet again.
model ProviderTransaction {
  id              String       @id @default(cuid())
  providerId      String
  provider        GameProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  externalId      String // provider's transaction id (unique per provider)
  action          String // BET | WIN | ROLLBACK
  userId          String
  gameId          String?
  externalRoundId String?
  currency        String
  amount          Decimal      @db.Decimal(38, 18)
  ledgerTxId      String? // wallet Transaction id this callback produced (null for IGNORED)
  status          String       @default("COMPLETED") // COMPLETED | IGNORED
  response        Json? // serialized response body, replayed verbatim on duplicates
  createdAt       DateTime     @default(now())

  @@unique([providerId, externalId])
  @@index([userId, createdAt])
}

model Game {
  id       String  @id @default(cuid())
  key      String  @unique // "roulette"
  name     String
  type     String // "roulette" | "slots" | "crash" | ...
  // Catalog taxonomy — drives the lobby/games grid. Kept as free-form strings so
  // new providers/categories can be added (seed or admin) without code changes.
  category String  @default("ROULETTE") // ROULETTE | SLOTS | LIVE | MINIGAME | ...
  provider String  @default("KuKuMBA Originals")
  status   String  @default("LIVE") // LIVE | COMING_SOON
  /// internal SPA route for built-in games (e.g. "/roulette"); null for external/provider games
  route    String?

  // External-provider mapping: which aggregator serves this game and under
  // which id. Null for KuKuMBA Originals. (providerRefId, not providerId, to
  // avoid colliding with the display string `provider` above.)
  providerRefId String?
  providerRef   GameProvider? @relation(fields: [providerRefId], references: [id], onDelete: SetNull)
  externalId    String?

  rtp           Float    @default(0.973)
  enabled       Boolean  @default(true)
  minBet        Decimal  @default(0.1) @db.Decimal(38, 18)
  maxBet        Decimal  @default(100000) @db.Decimal(38, 18)
  descriptionRu String?
  descriptionEn String?
  thumbnail     String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  rounds GameRound[]
  bets   Bet[]

  @@unique([providerRefId, externalId])
  @@index([enabled, sortOrder])
}

model ProvablyFairSeed {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverSeed     String // secret until revealed (rotation)
  serverSeedHash String
  clientSeed     String
  nonce          Int       @default(0)
  active         Boolean   @default(true)
  revealedAt     DateTime?
  createdAt      DateTime  @default(now())

  rounds GameRound[]

  @@index([userId, active])
}

model GameRound {
  id             String     @id @default(cuid())
  gameId         String
  game           Game       @relation(fields: [gameId], references: [id])
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  seedId         String
  seed           ProvablyFairSeed @relation(fields: [seedId], references: [id])
  serverSeedHash String
  clientSeed     String
  nonce          Int
  outcome        Int // pocket 0..36
  outcomeColor   String // "red" | "black" | "green"
  currency       String
  mode           WalletMode
  totalStake     Decimal    @db.Decimal(38, 18)
  totalPayout    Decimal    @default(0) @db.Decimal(38, 18)
  createdAt      DateTime   @default(now())

  bets Bet[]

  @@index([gameId, createdAt])
  @@index([userId, createdAt])
}

/// All-time leaderboards (biggest wins by USD, biggest multipliers). A dedicated,
/// permanently-bounded store (≤500 rows per board) so the top stays durable even
/// after the source GameRound is pruned by retention — and storage never grows.
model LeaderboardEntry {
  id        String   @id @default(cuid())
  board     String // "WINS" (ranked by usd) | "X" (ranked by coeff)
  roundId   String
  gameKey   String
  gameName  String
  category  String
  username  String
  accountId Int
  currency  String
  stake     Decimal  @db.Decimal(38, 18)
  payout    Decimal  @db.Decimal(38, 18)
  usd       Float // payout in USD-equivalent — ranking key for WINS
  coeff     Float // payout / stake — ranking key for X
  at        DateTime // when the round happened
  createdAt DateTime @default(now())

  @@unique([board, roundId])
  @@index([board, usd])
  @@index([board, coeff])
  @@index([board, gameKey])
}

model Bet {
  id         String     @id @default(cuid())
  roundId    String
  round      GameRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  gameId     String
  game       Game       @relation(fields: [gameId], references: [id])
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  betType    String // STRAIGHT | RED | BLACK | EVEN | ODD | LOW | HIGH | DOZEN_1..3 | COLUMN_1..3
  selection  Json // e.g. { "number": 7 } for STRAIGHT, {} otherwise
  stake      Decimal    @db.Decimal(38, 18)
  currency   String
  mode       WalletMode
  multiplier Decimal    @db.Decimal(38, 18) // gross multiplier on win (stake * multiplier returned)
  payout     Decimal    @default(0) @db.Decimal(38, 18)
  status     BetStatus  @default(PENDING)
  createdAt  DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([roundId])
}

// ── Bonuses / promo / referral / VIP / cashback ────────────────────────────────

model Bonus {
  id              String    @id @default(cuid())
  key             String    @unique
  name            String
  type            BonusType
  currency        String?
  amount          Decimal   @default(0) @db.Decimal(38, 18)
  percent         Float? // deposit match %
  maxAmount       Decimal?  @db.Decimal(38, 18)
  wagerMultiplier Float     @default(0)
  minDeposit      Decimal?  @db.Decimal(38, 18)
  requiresDeposit Boolean   @default(false) // claimable only after a completed deposit
  depositWithinDays Int? // require a qualifying deposit within N days (null = ever)
  sticky          Boolean   @default(true) // principal removed on clearing (only winnings cash out)
  maxCashoutMultiplier Float? // cap kept winnings at N× the bonus (null = uncapped)
  maxCashout      Decimal?  @db.Decimal(38, 18) // absolute winnings cap in the bonus currency
  availableUntil  DateTime? // offer window: hidden from catalog / not claimable after this
  wagerPeriodHours Int? // time allowed to complete wagering (null = unlimited)
  enabled         Boolean   @default(true)
  descriptionRu   String?
  descriptionEn   String?
  createdAt       DateTime  @default(now())

  userBonuses UserBonus[]
}

model UserBonus {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bonusId       String?
  bonus         Bonus?      @relation(fields: [bonusId], references: [id])
  name          String
  amount        Decimal     @db.Decimal(38, 18)
  currency      String
  mode          WalletMode  @default(REAL)
  wagerRequired Decimal     @default(0) @db.Decimal(38, 18)
  wagerProgress Decimal     @default(0) @db.Decimal(38, 18)
  status        BonusStatus @default(ACTIVE)
  sticky        Boolean     @default(false) // principal removed on clearing (only winnings cash out)
  maxCashout    Decimal?    @db.Decimal(38, 18) // resolved absolute winnings cap (bonus currency)
  baseline      Decimal     @default(0) @db.Decimal(38, 18) // player's own funds at grant (deposit); shielded from caps
  expiresAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId, status])
}

model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique
  type           PromoType
  currency       String?
  amount         Decimal   @default(0) @db.Decimal(38, 18)
  bonusKey       String?
  mode           WalletMode @default(REAL)
  maxRedemptions Int? // null = unlimited
  perUserLimit   Int       @default(1)
  requiresDeposit Boolean  @default(false) // redeemable only after a completed deposit
  depositWithinDays Int? // require a qualifying deposit within N days (null = ever)
  minDeposit     Decimal?  @db.Decimal(38, 18) // min qualifying deposit (USD-equiv)
  wagerMultiplier Float    @default(0) // wager on a granted BONUS/FREEBET (0 = instantly cleared)
  wagerPeriodHours Int? // time allowed to complete wagering (null = unlimited)
  sticky         Boolean   @default(true) // granted bonus is sticky (principal removed on clearing)
  maxCashoutMultiplier Float? // cap kept winnings at N× the granted amount
  maxCashout     Decimal?  @db.Decimal(38, 18) // absolute winnings cap in the promo currency
  redeemedCount  Int       @default(0)
  enabled        Boolean   @default(true)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  redemptions PromoRedemption[]
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([promoCodeId])
  @@index([userId])
}

/// Referral earnings history — one row each time a referral's net losses turn
/// into commission for the referrer (see ReferralCommission.pending flushes).
model ReferralEarning {
  id         String     @id @default(cuid())
  referrerId String
  referrer   User       @relation("ReferralEarner", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId String
  referred   User       @relation("ReferralSource", fields: [referredId], references: [id], onDelete: Cascade)
  currency   String
  mode       WalletMode @default(REAL)
  amount     Decimal    @db.Decimal(38, 18)
  type       String // "loss_commission"
  createdAt  DateTime   @default(now())

  @@index([referrerId, createdAt])
}

/// Revenue-share ledger per (referrer, referral, currency). `pending` is the
/// negative-carryover buffer: each settled round adds commission% × (stake −
/// payout), so a referral's WIN drives it below zero and later losses must
/// refill the hole before new commission is earned — the casino can never pay
/// out more than its share of that player's real net losses. Whenever `pending`
/// turns positive it is flushed into the referrer's claimable ReferralBalance.
model ReferralCommission {
  id         String   @id @default(cuid())
  referrerId String
  referrer   User     @relation("ReferralCommissionEarner", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId String
  referred   User     @relation("ReferralCommissionSource", fields: [referredId], references: [id], onDelete: Cascade)
  currency   String
  pending    Decimal  @default(0) @db.Decimal(38, 18) // carryover; ≤ 0 between flushes
  earned     Decimal  @default(0) @db.Decimal(38, 18) // lifetime flushed from this referral
  updatedAt  DateTime @updatedAt

  @@unique([referrerId, referredId, currency])
  @@index([referrerId])
}

/// The referrer's claimable commission per currency. Claiming credits the
/// wallet floored to the currency's precision — the dust stays claimable.
model ReferralBalance {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    User     @relation("ReferralBalanceOwner", fields: [referrerId], references: [id], onDelete: Cascade)
  currency    String
  amount      Decimal  @default(0) @db.Decimal(38, 18) // claimable now
  earnedTotal Decimal  @default(0) @db.Decimal(38, 18) // lifetime earned (stats)
  updatedAt   DateTime @updatedAt

  @@unique([referrerId, currency])
}

/// The VIP ladder (fully data-driven, seeded 0–20 with My Little Pony ranks).
/// A level is reached when the player's lifetime REAL deposits AND wagers (both
/// USD-equivalent) meet the two thresholds; the seed keeps wagerRequiredUsd at
/// 5× depositRequiredUsd, but each row is independently tunable by an operator.
model VipLevel {
  level              Int     @id
  name               String
  /// Emblem shown beside the nickname (profile, chat): the KEY of a built-in
  /// SVG glyph (web/src/components/VipEmblem.tsx), e.g. "horseshoe", "gem".
  icon               String?
  depositRequiredUsd Decimal @default(0) @db.Decimal(38, 18)
  wagerRequiredUsd   Decimal @default(0) @db.Decimal(38, 18)
  /// Weekly cashback: % of (deposits − withdrawals) over the trailing 7 days.
  cashbackPercent    Float   @default(0)
  /// Rakeback: share (%) of the house edge on each real bet returned to the player.
  rakebackPercent    Float   @default(0)
  color              String?
  perksRu            String?
  perksEn            String?
}

/// One weekly cashback payout. The base is (deposits − withdrawals) over the
/// claim window, aggregated in USD across all currencies; the payout lands in
/// the player's dominant deposit currency of that week.
model CashbackClaim {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  currency    String // payout currency
  mode        WalletMode @default(REAL)
  baseUsd     Decimal    @db.Decimal(38, 18) // net deposits of the week, USD-equivalent
  percent     Float
  amount      Decimal    @db.Decimal(38, 18) // payout in `currency`
  status      String     @default("PENDING") // PENDING | CLAIMED | EXPIRED
  claimedAt   DateTime?
  createdAt   DateTime   @default(now())

  @@index([userId, status])
}

/// Pending rakeback, accrued per REAL bet in the bet's currency:
/// stake × houseEdge × VipLevel.rakebackPercent. Claiming credits the wallet
/// (floored to the currency's precision — the sub-cent dust stays accrued).
model RakebackAccrual {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency    String
  amount      Decimal  @default(0) @db.Decimal(38, 18) // claimable now
  earnedTotal Decimal  @default(0) @db.Decimal(38, 18) // lifetime accrued (stats)
  updatedAt   DateTime @updatedAt

  @@unique([userId, currency])
}

// ── Raffles / giveaways ────────────────────────────────────────────────────────

model Raffle {
  id             String            @id @default(cuid())
  title          String
  descriptionRu  String?
  descriptionEn  String?
  creatorType    RaffleCreatorType @default(ADMIN)
  creatorName    String?
  createdById    String?
  currency       String
  mode           WalletMode        @default(REAL)
  prizePool      Decimal           @db.Decimal(38, 18)
  winnersCount   Int               @default(1)
  entryCost      Decimal           @default(0) @db.Decimal(38, 18)
  maxEntriesPerUser Int            @default(1)
  status         RaffleStatus      @default(OPEN)
  serverSeed     String?
  serverSeedHash String?
  clientSeed     String?
  opensAt        DateTime?
  closesAt       DateTime?
  drawAt         DateTime?

  // entry conditions (Phase 11)
  requiresDeposit   Boolean        @default(false)
  minDeposit        Decimal?       @db.Decimal(38, 18) // USD-equivalent threshold (any deposit currency, via Currency.usdRate)
  depositWithinDays Int?           // qualifying-deposit window: 1 / 7 / 14 / 30
  minVipLevel       Int?           // VIP-exclusive raffles: entry needs this VIP level or higher
  audience          RaffleAudience @default(ALL)
  partnerId         String?        // audience=PARTNER_REFERRALS: only this partner's referrals may enter

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  entries RaffleEntry[]
  winners RaffleWinner[]

  @@index([status])
  @@index([status, drawAt])
}

model RaffleEntry {
  id        String   @id @default(cuid())
  raffleId  String
  raffle    Raffle   @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tickets   Int      @default(1)
  createdAt DateTime @default(now())

  @@index([raffleId])
  @@index([userId])
}

model RaffleWinner {
  id        String   @id @default(cuid())
  raffleId  String
  raffle    Raffle   @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prize     Decimal  @db.Decimal(38, 18)
  rank      Int
  createdAt DateTime @default(now())

  @@index([raffleId])
}

// ── Social: chat & notifications ───────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  room      String   @default("global")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username  String
  body      String
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([room, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(SYSTEM)
  titleRu   String
  titleEn   String
  bodyRu    String
  bodyEn    String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
}

// ── Compliance: KYC, support, responsible gaming ───────────────────────────────

model KycCase {
  id          String        @id @default(cuid())
  userId      String        @unique
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      KycStatus     @default(PENDING)
  level       Int           @default(1)
  fullName    String?
  dateOfBirth DateTime?
  country     String?
  reviewerId  String?
  reviewNote  String?
  reviewedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  documents KycDocument[]
}

model KycDocument {
  id        String    @id @default(cuid())
  caseId    String
  case      KycCase   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  kind      String // passport | id_card | selfie | proof_of_address
  fileUrl   String
  status    KycStatus @default(PENDING)
  createdAt DateTime  @default(now())

  @@index([caseId])
}

model SupportTicket {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      String
  category     String         @default("general")
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(NORMAL)
  assignedToId String?
  // When the ticket was last moved to CLOSED — drives attachment retention
  // (files are pruned N days after closing; the ticket record is kept).
  closedAt     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  messages SupportMessage[]

  @@index([userId])
  @@index([status])
}

model SupportMessage {
  id            String        @id @default(cuid())
  ticketId      String
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId      String
  authorRole    UserRole
  body          String
  attachmentUrl String?
  attachmentName String? // uploader's original filename (shown in the thread / on download)
  attachmentSize Int? // bytes, for the file chip in the UI
  createdAt     DateTime      @default(now())

  @@index([ticketId])
}

model RgLimit {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      RgLimitType
  period    String // DAILY | WEEKLY | MONTHLY
  amount    Decimal?    @db.Decimal(38, 18)
  minutes   Int?
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([userId, type, period])
}

model SelfExclusion {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  until     DateTime? // null = permanent
  reason    String?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ── Platform: settings, content, audit, counters ───────────────────────────────

model AppSetting {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}

model ContentPage {
  id        String   @id @default(cuid())
  key       String // responsible-gaming | contacts | privacy | private-game | terms | about
  locale    String // ru | en
  title     String
  body      String
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorName  String?
  action     String
  targetType String?
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

/// Editable RBAC matrix: which non-admin staff role may perform which capability.
/// The capability catalog lives in code (permissions.registry.ts); ADMIN always
/// passes every check and is never stored here.
model RolePermission {
  id         String   @id @default(cuid())
  role       UserRole
  permission String
  allowed    Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  @@unique([role, permission])
  @@index([role])
}

/// Atomic counters (e.g. sequential public Account IDs).
model Counter {
  key   String @id
  value Int    @default(0)
}
